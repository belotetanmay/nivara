{
  "expo": {
    "name": "NIVARA",
    "slug": "nivara-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logonew.png",
    "scheme": "nivara",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logonew.png",
      "bundleIdentifier": "com.nivara.app",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F2D52",
        "foregroundImage": "./assets/images/logonew.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.nivara.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F2D52",
          "image": "./assets/images/logonew.png",
          "imageWidth": 120
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef125790-a93c-4429-8397-89294ac9a803"
      }
    }
  }
}
